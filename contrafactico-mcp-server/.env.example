NODE_ENV=development
USE_LOCAL_CORPUS=true
PORT=3100
AUTH_MODE=disabled
DEMO_ENDPOINTS_PUBLIC=true
DEV_BEARER_TOKEN=YOUR-LOCAL-DEVELOPMENT-TOKEN

ENTRA_TENANT_ID=YOUR-TENANT-ID
ENTRA_AUDIENCE=api://YOUR-APPLICATION-ID
ENTRA_ISSUER=https://login.microsoftonline.com/YOUR-TENANT-ID/v2.0
ENTRA_JWKS_URI=https://login.microsoftonline.com/YOUR-TENANT-ID/discovery/v2.0/keys

SEARCH_ENDPOINT=https://YOUR-SEARCH-SERVICE.search.windows.net
SEARCH_KB_NAME=contrafactico-kb
SEARCH_API_VERSION=2026-05-01-preview
SEARCH_API_KEY=YOUR-SEARCH-ADMIN-OR-QUERY-KEY
FOUNDRY_DEBUG_SHAPE=false

AOAI_ENDPOINT=https://YOUR-AOAI-RESOURCE.openai.azure.com
AOAI_DEPLOYMENT=gpt-41-reasoning
AOAI_API_VERSION=2025-04-01-preview
AOAI_API_KEY=YOUR-AOAI-KEY

CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3100
