{
  "name": "contrafactico-mcp-server",
  "version": "0.1.0",
  "private": true,
  "description": "Stateless Streamable HTTP MCP server for CONTRAFÁCTICO.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check:local": "tsx src/devCheck.ts",
    "dev": "tsx watch src/index.ts",
    "generate:corpus": "tsx ../scripts/generate_corpus.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "express": "5.1.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/express": "5.0.3",
    "@types/node": "24.0.3",
    "tsx": "4.20.3",
    "typescript": "5.8.3"
  }
}
